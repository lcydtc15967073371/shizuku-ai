<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="6dp">

    <!-- 顶部栏：拖拽区 + 操作按钮 -->
    <LinearLayout
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- 左侧状态文字 -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Shizuku AI"
            android:textSize="11sp"
            android:textColor="#888888" />

        <!-- Token按钮（小圆点） -->
        <Button
            android:id="@+id/btn_token_setup"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:text="🔑"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444444"
            android:paddingHorizontal="6dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginEnd="4dp" />

        <!-- 关闭按钮 -->
        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_close"
            android:contentDescription="关闭"
            android:backgroundTint="#444444" />
    </LinearLayout>

    <!-- ============ AI 对话区域 ============ -->
    <LinearLayout
        android:id="@+id/ai_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 输入栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A4488FF"
            android:padding="3dp"
            android:layout_marginTop="3dp">

            <EditText
                android:id="@+id/ai_input"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:textColorHint="#66FFFFFF"
                android:hint="说需求..."
                android:singleLine="true"
                android:imeOptions="actionGo"
                android:background="@android:color/transparent"
                android:paddingHorizontal="6dp" />

            <ImageButton
                android:id="@+id/btn_ai_send"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_run"
                android:contentDescription="发送" />

            <Button
                android:id="@+id/btn_ai_clear"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:text="✕"
                android:textSize="12sp"
                android:textColor="#FF8888"
                android:backgroundTint="#553333"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:contentDescription="清除" />
        </LinearLayout>

        <!-- 输出区域（可展开折叠） -->
        <ScrollView
            android:id="@+id/ai_output_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="200dp"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/ai_output_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#DDDDDD"
                android:lineSpacingExtra="1dp"
                android:padding="4dp" />
        </ScrollView>
    </LinearLayout>

    <!-- ============ CMD 模式区域 ============ -->
    <LinearLayout
        android:id="@+id/normal_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- 命令输入 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1AFFFFFF"
            android:padding="3dp"
            android:layout_marginTop="3dp">

            <EditText
                android:id="@+id/input_cmd"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:textColorHint="#66FFFFFF"
                android:hint="输入命令"
                android:singleLine="true"
                android:imeOptions="actionGo"
                android:background="@android:color/transparent"
                android:paddingHorizontal="6dp" />

            <ImageButton
                android:id="@+id/btn_exec"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_run" />
        </LinearLayout>

        <!-- 输出 -->
        <ScrollView
            android:id="@+id/output_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="150dp"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/output_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#AAFFAA"
                android:lineSpacingExtra="1dp"
                android:padding="4dp" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
