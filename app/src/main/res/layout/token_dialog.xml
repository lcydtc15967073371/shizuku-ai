<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🤖 AI API 配置"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="API密钥 (Token)"
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/dialog_token_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textColorHint="#66FFFFFF"
        android:hint="sk-xxxxxxxxxxxxxxxxxxxxx"
        android:inputType="text"
        android:singleLine="true"
        android:background="#1AFFFFFF"
        android:padding="10dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="API端点地址 (可选，默认DeepSeek)"
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/dialog_endpoint_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textColorHint="#66FFFFFF"
        android:hint="https://api.deepseek.com/v1/chat/completions"
        android:inputType="textUri"
        android:singleLine="true"
        android:background="#1AFFFFFF"
        android:padding="10dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="模型名称 (可选)"
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/dialog_model_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textColorHint="#66FFFFFF"
        android:hint="deepseek-chat"
        android:inputType="text"
        android:singleLine="true"
        android:background="#1AFFFFFF"
        android:padding="10dp"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_token_clear"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="清除Token"
            android:textColor="#FF6666"
            android:backgroundTint="#442222"
            android:textSize="13sp"
            android:paddingHorizontal="12dp" />

        <Button
            android:id="@+id/btn_token_cancel"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="取消"
            android:textColor="#AAAAAA"
            android:backgroundTint="#444444"
            android:textSize="13sp"
            android:paddingHorizontal="12dp"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btn_token_save"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="保存"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4488FF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>
